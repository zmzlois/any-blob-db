{
  "name": "any-blob-db",
  "version": "0.1.6",
  "description": "use vercel blob, s3, or r2 as a lightweight json database with drizzle-inspired syntax",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/basic.ts",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "check": "biome check ."
  },
  "peerDependencies": {
    "@vercel/blob": ">=2.0.0",
    "aws4fetch": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@vercel/blob": {
      "optional": true
    },
    "aws4fetch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.0",
    "@vercel/blob": "^2.4.0",
    "aws4fetch": "^1.0.20",
    "tsup": "^8.0.0",
    "tsx": "^4.22.2",
    "typescript": "^5.0.0"
  }
}
